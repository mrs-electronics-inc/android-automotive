workspace := "/srv/android-automotive"
release := "imx-automotive-16.0.0_1.1.0"
source_tree := workspace + "/" + release + "/android_build"
images_dir := workspace + "/releases/" + release
build_log := workspace + "/build.log"
build_cid := workspace + "/build.cid"

default:
  @just --list

install-repo:
  sudo curl https://storage.googleapis.com/git-repo-downloads/repo -o /usr/local/bin/repo
  sudo chmod +x /usr/local/bin/repo

extract-bsp archive=(release + ".tar.gz"):
  cd {{workspace}} && tar -xzvf {{archive}}

build: build-container build-images

build-container:
  cd {{source_tree}}/device/nxp/common/dockerbuild && docker build --no-cache \
    --build-arg userid=$(id -u) \
    --build-arg groupid=$(id -g) \
    --build-arg username=$(id -un) \
    -t android-build .

build-images:
  rm -f {{build_cid}} {{build_log}}
  docker run -d --cidfile {{build_cid}} --entrypoint /bin/bash --privileged -v {{source_tree}}:/work/android_src android-build -lc '\
    cd /work/android_src && \
    source build/envsetup.sh && \
    lunch mek_8q_car2-nxp_stable-userdebug && \
    ./imx-make.sh -j3 2>&1 | tee build-log.txt' > {{build_log}}
  cat {{build_cid}}

build-status:
  docker ps -a --filter "id=$(cat {{build_cid}} 2>/dev/null)" || true

build-logs:
  docker logs $(cat {{build_cid}})

publish: publish-artifacts

publish-artifacts:
  mkdir -p {{images_dir}}
  cp -r {{workspace}}/{{release}}/out/target/product/mek_8q {{images_dir}}/
  cp {{workspace}}/{{release}}/build-log.txt {{images_dir}}/ 2>/dev/null || true

verify-artifacts:
  ls -al {{images_dir}}
  ls -al {{images_dir}}/mek_8q
