android_app {
    name: "DisplayApp",
    platform_apis: true,
    certificate: "platform",
    srcs: ["app/src/main/**/*.java", "app/src/main/**/*.kt"],
    resource_dirs: ["app/src/main/res"],
    manifest: "app/src/main/AndroidManifest.xml",

    static_libs: [
        "androidx.appcompat_appcompat",
        "androidx.constraintlayout_constraintlayout",
        "android.car",
    ],
}
