<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Hero: speedometer fills the upper region; gear is drawn inside as a badge. -->
    <com.mrselectronics.gaugecluster.GaugeView
        android:id="@+id/speed_gauge"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Thin divider between hero and status rail. -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        android:background="#FF202A2A"/>

    <!-- Status rail: tertiary readouts (RPM / FUEL / RANGE). -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:divider="@drawable/status_rail_divider"
        android:dividerPadding="16dp"
        android:showDividers="middle">

        <com.mrselectronics.gaugecluster.StatusReadoutView
            android:id="@+id/rpm_readout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <com.mrselectronics.gaugecluster.StatusReadoutView
            android:id="@+id/energy_readout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>

        <com.mrselectronics.gaugecluster.StatusReadoutView
            android:id="@+id/range_readout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
